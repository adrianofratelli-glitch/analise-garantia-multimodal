# MongoDB Atlas — nunca commitar o .env real
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=analise_garantia
MONGODB_COLLECTION=chamados
MONGODB_CATALOGO_COLLECTION=catalogo
MONGODB_PEDIDOS_COLLECTION=pedidos
MONGODB_CATALOGO_FOTOS_COLLECTION=catalogo_fotos
VECTOR_INDEX_NAME=defeitos_vector_index
TEXT_INDEX_NAME=chamados_text_index
CATALOGO_FOTOS_VECTOR_INDEX_NAME=catalogo_fotos_vector_index

# Anthropic (Claude visão, tool use forçado)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=1024

# Voyage AI (embedding multimodal manual)
VOYAGE_API_KEY=pa-...
EMBEDDING_MODEL=voyage-multimodal-3.5
EMBEDDING_DIMENSIONS=1024

# Imagens — storage LOCAL no PoV (em prod, trocar storage.py por S3 + CDN)
# MEDIA_ROOT=./media          # padrão: backend/media
# MAX_IMAGE_BYTES=10485760     # 10 MB
