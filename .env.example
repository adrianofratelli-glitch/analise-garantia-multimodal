# MongoDB Atlas (nunca commite o .env real)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Anthropic (veredito com visão — claude-opus-4-8)
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI (embedding multimodal — voyage-multimodal-3)
VOYAGE_API_KEY=pa-...

# S3 (imagens dos chamados)
S3_BUCKET=mm-analise-garantia
AWS_REGION=us-east-1
# credenciais AWS via ambiente padrão do boto3:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
