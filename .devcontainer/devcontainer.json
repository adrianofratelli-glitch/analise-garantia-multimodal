{
  "name": "MM Análise de Garantia",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/python:1": { "version": "3.11" },
    "ghcr.io/devcontainers/features/node:1": { "version": "20" }
  },
  "forwardPorts": [8000, 5173],
  "portsAttributes": {
    "8000": { "label": "FastAPI (backend)" },
    "5173": { "label": "Vite (frontend)" }
  },
  "postCreateCommand": "python -m venv backend/.venv && backend/.venv/bin/pip install -r backend/requirements.txt && cd frontend && npm install",
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "dbaeumer.vscode-eslint"]
    }
  }
}
